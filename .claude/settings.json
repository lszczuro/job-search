{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./.env.local)",
      "Read(./secrets/**)",
      "Bash(git push *)",
      "Bash(git push --force*)",
      "Bash(rm -rf *)"
    ],
    "allow": [
      "Bash(npm run lint*)",
      "Bash(npm test*)",
      "Bash(npm ci*)",
      "Bash(pnpm install*)",
      "Bash(pnpm lint*)",
      "Bash(pnpm test*)",
      "Bash(python -m pytest*)",
      "Bash(uv sync*)",
      "Bash(uv run*)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git worktree*)",
      "Read"
    ]
  }
}
